{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m1-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.cheapcheap.com.au/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m1-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.cheapcheap.com.au/v1"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m1-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.cheapcheap.com.au/v1",
        "EXPO_PUBLIC_SUPABASE_URL": "https://nrydajhckurgeuguvhfx.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_cU7IA9MQCOkvJZhWMB55OA_il947IE2"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "developer@cheapcheap.com.au",
        "ascAppId": "FILL_IN_APP_STORE_CONNECT_ID",
        "appleTeamId": "FILL_IN_APPLE_TEAM_ID"
